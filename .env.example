# ── Deployment ──────────────────────────────────────────────────────
# Mode (REQUIRED): "standalone" or "shared"
# standalone = own droplet via Terraform (requires DO_API_TOKEN)
# shared     = deploy to an existing droplet (requires DROPLET_IP + SSH_KEY)
DEPLOY_MODE=standalone

# Droplet IP address (from Terraform output, or provided by host in shared mode)
# DROPLET_IP=1.2.3.4

# DigitalOcean API token (standalone mode only — can be removed after first deploy)
# DO_API_TOKEN=your-digitalocean-api-token

# SSH key for droplet access (shared mode only).
# In standalone mode, Terraform generates and saves the key automatically
# to ~/.ssh/ibkr-bridge — you never need to set this.
# Only set this in shared mode, using the key provided by the droplet owner.
# SSH_KEY=~/.ssh/shared-droplet

# Override droplet size slug (standalone mode only).
# When set, ignores JAVA_HEAP_SIZE for droplet sizing.
# DROPLET_SIZE=s-1vcpu-1gb

# Docker network name for cross-project communication on the same droplet.
# Set to the same value across all projects that need to reach each other's containers.
# Leave unset for isolated standalone deployment.
# SHARED_NETWORK=relay-net

# ── IB Gateway ─────────────────────────────────────────────────────
TWS_USERID=
TWS_PASSWORD=
VNC_SERVER_PASSWORD=
TRADING_MODE=paper

# Username for VNC domain basic auth (default: admin)
# VNC_BASIC_AUTH_USER=admin

# IB Gateway memory allocation in MB (default: 768)
# Higher values allow faster data retrieval. Recommended: 4096 for API use.
# Droplet size is auto-selected based on this value (max: 10240).
JAVA_HEAP_SIZE=768

# ── Domains ────────────────────────────────────────────────────────
# DNS A records must point to droplet IP.
VNC_DOMAIN=vnc.example.com
SITE_DOMAIN=trade.example.com

# ── API Authentication ─────────────────────────────────────────────
# Bearer token for /ibkr/* endpoints (generate with: openssl rand -hex 32)
API_TOKEN=

# ── WebSocket Event Streaming ─────────────────────────────────────
# Ring buffer size for event replay on client reconnect (default: 500)
# WS_BUFFER_SIZE=500

# Max simultaneous WebSocket subscribers (default: 10)
# WS_MAX_SUBSCRIBERS=10

# WebSocket ping interval in seconds for zombie detection (default: 30)
# WS_HEARTBEAT_INTERVAL=30

# ── General ────────────────────────────────────────────────────────
TIME_ZONE=America/New_York

# Bridge service log level (default: INFO)
# Valid values: DEBUG, INFO, WARNING, ERROR, CRITICAL
# LOG_LEVEL=INFO

# CLI default target environment: "prod" (HTTPS via SITE_DOMAIN) or "local" (localhost:15101)
# Override per-command with: make order ENV=local
DEFAULT_CLI_BRIDGE_ENV=prod
